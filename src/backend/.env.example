# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/heimat_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-token
JWT_EXPIRES_IN=7d

# Open Source APIs
OPENROUTESERVICE_API_KEY=your-api-key
OPENTRANSPORT_API_KEY=your-api-key

# GNU Taler
TALER_EXCHANGE_URL=https://exchange.taler.net
TALER_MERCHANT_URL=https://merchant.taler.net

# Logging
LOG_LEVEL=info
